<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.hello.mapper.EmployeeProjectHistoryMapper">
    
    <resultMap id="BaseResultMap" type="com.example.hello.entity.EmployeeProjectHistory">
        <id column="id" property="id"/>
        <result column="employee_id" property="employeeId"/>
        <result column="project_id" property="projectId"/>
        <result column="employee_name" property="employeeName"/>
        <result column="job_category_name" property="jobCategoryName"/>
        <result column="join_time" property="joinTime"/>
        <result column="leave_time" property="leaveTime"/>
        <result column="create_time" property="createTime"/>
    </resultMap>
    
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tb_employee_project_history 
        (employee_id, project_id, employee_name, job_category_name, join_time, leave_time)
        VALUES 
        (#{employeeId}, #{projectId}, #{employeeName}, #{jobCategoryName}, #{joinTime}, #{leaveTime})
    </insert>
    
    <select id="selectByProjectId" resultMap="BaseResultMap">
        SELECT * FROM tb_employee_project_history 
        WHERE project_id = #{projectId}
        ORDER BY leave_time DESC
    </select>
    
    <select id="selectByEmployeeAndProject" resultMap="BaseResultMap">
        SELECT * FROM tb_employee_project_history 
        WHERE employee_id = #{employeeId} AND project_id = #{projectId}
        LIMIT 1
    </select>
    
</mapper>
