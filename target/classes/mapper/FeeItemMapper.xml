<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.hello.mapper.FeeItemMapper">

    <resultMap id="BaseResultMap" type="com.example.hello.entity.FeeItem">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="type" property="type"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tb_fee_item (name, type, status, create_time, update_time)
        VALUES (#{name}, #{type}, #{status}, NOW(), NOW())
    </insert>

    <update id="update">
        UPDATE tb_fee_item
        SET name = #{name},
            type = #{type},
            status = #{status},
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM tb_fee_item WHERE id = #{id}
    </delete>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM tb_fee_item WHERE id = #{id}
    </select>

    <select id="selectAllEnabled" resultMap="BaseResultMap">
        SELECT * FROM tb_fee_item WHERE status = 1 ORDER BY type, id
    </select>

    <select id="selectByType" resultMap="BaseResultMap">
        SELECT * FROM tb_fee_item WHERE type = #{type} AND status = 1 ORDER BY id
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM tb_fee_item ORDER BY type, id
    </select>

</mapper>
