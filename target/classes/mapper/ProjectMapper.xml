<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.hello.mapper.ProjectMapper">

    <resultMap id="BaseResultMap" type="com.example.hello.entity.Project">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM tb_project WHERE id = #{id}
    </select>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT * FROM tb_project ORDER BY create_time DESC
    </select>

    <select id="findByEmployeeId" resultMap="BaseResultMap">
        SELECT p.* FROM tb_project p
        INNER JOIN tb_employee_project ep ON p.id = ep.project_id
        WHERE ep.employee_id = #{employeeId}
        ORDER BY p.create_time DESC
    </select>

    <select id="findByAdminId" resultType="com.example.hello.entity.Project">
        SELECT p.* FROM tb_project p
        INNER JOIN tb_project_admin pa ON p.id = pa.project_id
        WHERE pa.employee_id = #{adminId}
        ORDER BY p.create_time DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tb_project (name) VALUES (#{name})
    </insert>

    <update id="update">
        UPDATE tb_project SET name = #{name} WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM tb_project WHERE id = #{id}
    </delete>

</mapper>
